# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Tencent Cloud COS (optional): stores user scan images in the cloud.
# If omitted, images are saved to the local data/images directory.
# Get these values from your Tencent Cloud COS console.
TENCENT_COS_SECRET_ID="MY_TENCENT_COS_SECRET_ID"
TENCENT_COS_SECRET_KEY="MY_TENCENT_COS_SECRET_KEY"
TENCENT_COS_BUCKET="mybucket-1250000000"
TENCENT_COS_REGION="ap-guangzhou"
# Optional object-key prefix (no trailing slash). Defaults to "catscope".
TENCENT_COS_PREFIX="catscope"
